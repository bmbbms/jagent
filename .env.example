# Application
ACQUIRING_AI_APP_NAME=Acquiring AI
ACQUIRING_AI_ENV=dev
ACQUIRING_AI_DEBUG=true
ACQUIRING_AI_API_PREFIX=/api

# Runtime
ACQUIRING_AI_AGENT_RUNTIME=agentscope
ACQUIRING_AI_CAPABILITY_REGISTRY_BACKEND=local
ACQUIRING_AI_CAPABILITY_MODULE_PACKAGES=["app.agents.capabilities"]
ACQUIRING_AI_ENABLED_DOMAINS=["merchant","operations","data_support"]
ACQUIRING_AI_SKILL_ROOT=app/skills
ACQUIRING_AI_TOOL_CATALOG_BACKEND=internal
ACQUIRING_AI_INTERNAL_TOOL_PROVIDER_BACKEND=local_db
ACQUIRING_AI_INTERNAL_TOOL_HTTP_BASE_URL=
ACQUIRING_AI_INTERNAL_TOOL_HTTP_TIMEOUT_SECONDS=10
ACQUIRING_AI_INTERNAL_TOOL_HTTP_BEARER_TOKEN=

# MCP
ACQUIRING_AI_MCP_ENABLED=false
ACQUIRING_AI_MCP_CONFIG_PATH=config/mcp.example.json

# Redis
ACQUIRING_AI_REDIS_URL=redis://127.0.0.1:6379/0

# Vector Store
ACQUIRING_AI_VECTOR_STORE_ENABLED=false
ACQUIRING_AI_VECTOR_STORE_PROVIDER=external

# AgentScope Bridge
ACQUIRING_AI_AGENTSCOPE_USE_MODEL_BRIDGE=false
ACQUIRING_AI_AGENTSCOPE_MODEL_NAME=
ACQUIRING_AI_AGENTSCOPE_API_KEY=
ACQUIRING_AI_AGENTSCOPE_BASE_URL=
ACQUIRING_AI_AGENTSCOPE_MAX_ITERS=6

# Database
ACQUIRING_AI_DATABASE_ENABLED=true
ACQUIRING_AI_DATABASE_URL=mysql+pymysql://jagent:jagent@127.0.0.1:3306/jagent?charset=utf8mb4
ACQUIRING_AI_MYSQL_DATABASE_URL=mysql+pymysql://jagent:jagent@127.0.0.1:3306/jagent?charset=utf8mb4
ACQUIRING_AI_POSTGRES_DATABASE_URL=postgresql+psycopg://acquiring_ai:acquiring_ai@127.0.0.1:5432/acquiring_ai
ACQUIRING_AI_DATABASE_ECHO=false
ACQUIRING_AI_DATABASE_AUTO_CREATE=false
ACQUIRING_AI_DATABASE_RUN_MIGRATIONS=true

# Nacos
ACQUIRING_AI_NACOS_ENABLED=false
ACQUIRING_AI_NACOS_SERVER_ADDRESS=127.0.0.1:8848
ACQUIRING_AI_NACOS_NAMESPACE=public
ACQUIRING_AI_NACOS_GROUP=DEFAULT_GROUP
ACQUIRING_AI_NACOS_SERVICE_PREFIX=agent
ACQUIRING_AI_NACOS_SERVICE_HOST=127.0.0.1
ACQUIRING_AI_NACOS_SERVICE_PORT=8000
ACQUIRING_AI_NACOS_SERVICE_PATH=/api/chat
ACQUIRING_AI_NACOS_SERVICE_CLUSTER=DEFAULT
ACQUIRING_AI_NACOS_SERVICE_WEIGHT=1.0
